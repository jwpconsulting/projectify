{
  "name": "projectify-tailwind",
  "version": "0.1",
  "description": "Projectify tailwindcss packages and scripts",
  "scripts": {
    "start": "npm run dev",
    "build": "npm run build:clean && npm run build:tailwind",
    "build:clean": "rm -r projectify/static/css/dist",
    "build:tailwind": "tailwindcss --postcss -i projectify/static_src/src/styles.css -o projectify/static/css/dist/styles.css",
    "dev": "tailwindcss --postcss -i projectify/static_src/src/styles.css -o projectify/static/css/dist/styles.css --watch",
    "tailwindcss": "node ./node_modules/tailwindcss/lib/cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "~10.4.19",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
