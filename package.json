{
  "name": "projectify-tailwind",
  "description": "Projectify tailwindcss packages and scripts",
  "scripts": {
    "start": "npm run tailwindcss -- --watch",
    "build": "rm projectify/static/css/dist/styles.css && npm run tailwindcss",
    "tailwindcss": "node ./node_modules/tailwindcss/lib/cli.js --postcss --input projectify/static_src/src/styles.css -o projectify/static/css/dist/styles.css"
  },
  "keywords": [],
  "author": "The Projectify Authors <hello@projectifyapp.com>",
  "maintainers": [
    "Justus Perlwitz <justus@jwpconsulting.net>"
  ],
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "~10.4.19",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
