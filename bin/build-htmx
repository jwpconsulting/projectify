#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# SPDX-FileCopyrightText: 2026 JWP Consulting GK
#
# Refresh htmx.js bundle file and check if it changed.
# See also `docs/frontend-scripting.md`
dest=projectify/static/htmx.js
cp "$(nix build .#htmx-bundle --print-out-paths --no-link)/htmx.js" "$dest"

if ! git diff --exit-code --quiet HEAD -- "$dest"; then
    echo "HTMX bundle has been updated. Please commit."
    exit 1
fi
