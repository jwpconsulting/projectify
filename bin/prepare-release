# Prepare a new version to be released
set -e
version="$(date "+%Y.%-m.%-d")"
hyphenated_version="$(date "+%Y-%-m-%-d")"
echo "Version: $version"

PYPROJECT_TOML="pyproject.toml"
UV_LOCK="uv.lock"

next_cmd=$(printf 'uv version "%s"' "$version")
printf "About to run %s\nContinue? (c-c to exit)" "$next_cmd"
read -r _
eval "$next_cmd"

next_cmd=$(printf "git add %s %s %s" "$PYPROJECT_TOML" "$UV_LOCK" "CHANGELOG.md")
printf "about to run %s\nContinue? (c-c to exit)" "$next_cmd"
read -r _
eval "$next_cmd"

next_cmd=$(printf 'git commit -m \"Set Projectify version to %s\"' "$version")
printf "about to run %s\nContinue? (c-c to exit)" "$next_cmd"
read -r _
eval "$next_cmd"

next_cmd=$(printf 'git tag %s' "$version")
printf "about to run %s\nContinue? (c-c to exit)" "$next_cmd"
read -r _
eval "$next_cmd"

branch_name=$(git rev-parse --abbrev-ref HEAD)
next_cmd=$(printf 'git push --setup-upstreadm origin %s' "$branch_name")
printf "about to run %s\nContinue? (c-c to exit)" "$next_cmd"
read -r _
eval "$next_cmd"

next_cmd="git push --tags"
printf "about to run %s\nContinue? (c-c to exit)" "$next_cmd"
read -r _
eval "$next_cmd"

echo "
1. Create a pull request:

   https://github.com/jwpconsulting/projectify/compare/${branch_name}

2. Merge your pull request.
3. Create a release on GitHub:

   https://github.com/jwpconsulting/projectify/releases/new?title=${version}&tag=${version}

4. Create a release blog post on Projectify:

   https://www.projectifyapp.com/admin/blog/post/add/?title=New%20Projectify%20release%20${hyphenated_version}&slug=projectify-release-${hyphenated_version}
"
