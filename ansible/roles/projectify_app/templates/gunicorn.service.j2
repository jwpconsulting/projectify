[Unit]
Description=gunicorn daemon
Requires=gunicorn.socket
After=network.target

[Service]
Type=notify
NotifyAccess=main
User=projectify
Group=projectify
WorkingDirectory=/var/lib/projectify/app
Environment="SOCKET=/run/gunicorn.sock"
# TODO remove SITE_TITLE var
Environment="SITE_TITLE=Projectify Production on Hetzner"
Environment="DJANGO_SETTINGS_MODULE=projectify.settings.hetzner"
Environment="DJANGO_CONFIGURATION=Hetzner"
# TODO hard-code in Hetzner class
Environment="DATABASE_URL=postgres://%%2Frun%%2Fpostgresql/projectify"
Environment="STATIC_ROOT={{ static_root }}"
Environment="MEDIA_ROOT={{ media_root }}"
# TODO use LoadCredential for secrets
Environment="CREDENTIALS_FILE={{ credentials_file }}"
# TODO configure logs
ExecStart=/var/lib/projectify/venv/bin/gunicorn
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true

[Install]
WantedBy=multi-user.target
